BOT_TOKEN=
# If BOT_TOKEN is not set, the bot reads the token from a file at BOT_TOKEN_FILE
# (used by Docker Compose / VPS deployments that inject tokens as secrets files).
# BOT_TOKEN_FILE=/run/secrets/bot_token
# Redis URL for persistent storage (optional — falls back to in-memory for dev/test).
# Set in production to persist Teams, Members, StandupRuns, and History across restarts.
# REDIS_URL=redis://localhost:6379
