[
  {
    "name": "Non-text message during standup answer flow guides user back",
    "steps": [
      {
        "send": { "callback": "team:create" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "✨ Let's set up your team!\n\nFirst, what's your team called?"
            }
          }
        ]
      },
      {
        "send": { "text": "PhotoTest" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Got it! Now let's set up your channel for digests.\n\n**Forward any message from your team's channel** to me — I'll grab the channel ID from it. That's the easiest way."
            }
          }
        ]
      },
      {
        "send": { "text": "-1006666666660" },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": { "callback": "standup:answer" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📋 Question 1 of 3\n\nWhat did you work on since the last standup?\n\nType your answer below:"
            }
          }
        ]
      },
      {
        "send": {
          "update": {
            "update_id": 200,
            "message": {
              "message_id": 200,
              "date": 0,
              "chat": { "id": 1, "type": "private", "first_name": "Test" },
              "from": { "id": 1, "is_bot": false, "first_name": "Test" },
              "photo": []
            }
          }
        },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "I'm waiting for your text answer. Tap /cancel if you want to stop, or type your response below."
            }
          }
        ]
      }
    ]
  }
]