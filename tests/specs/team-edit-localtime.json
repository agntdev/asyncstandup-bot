[
  {
    "name": "Edit team time in valid format",
    "steps": [
      {
        "send": { "callback": "team:create" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "✨ Let's set up your team!\n\nFirst, what's your team called?"
            }
          }
        ]
      },
      {
        "send": { "text": "SunriseCrew" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Got it! Now let's set up your channel for digests.\n\n**Forward any message from your team's channel** to me — I'll grab the channel ID from it. That's the easiest way."
            }
          }
        ]
      },
      {
        "send": { "text": "-1001111111110" },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": { "callback": "team:edit:localtime" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "What time should standup prompts go out each day?\n\nSend the time in 24-hour format (e.g. 09:00, 14:30):"
            }
          }
        ]
      },
      {
        "send": { "text": "14:30" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "✅ Standup prompt time set to 14:30 local time."
            }
          }
        ]
      }
    ]
  }
]