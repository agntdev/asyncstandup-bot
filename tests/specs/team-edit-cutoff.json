[
  {
    "name": "Edit cutoff and edit questions via settings",
    "steps": [
      {
        "send": { "callback": "team:create" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "✨ Let's set up your team!\n\nFirst, what's your team called?"
            }
          }
        ]
      },
      {
        "send": { "text": "Editors" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Got it! Now let's set up your channel for digests.\n\n**Forward any message from your team's channel** to me — I'll grab the channel ID from it. That's the easiest way."
            }
          }
        ]
      },
      {
        "send": { "text": "-1003333333330" },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": { "callback": "team:edit:cutoff" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "How many minutes after the standup prompt should the digest be compiled?\n\nSend a number (e.g. 60, 90, 120):"
            }
          }
        ]
      },
      {
        "send": { "text": "90" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "✅ Cutoff window set to 90 minutes."
            }
          }
        ]
      }
    ]
  }
]