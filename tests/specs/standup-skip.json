[
  {
    "name": "Standup skip flow — skip button marks user as skipped",
    "steps": [
      {
        "send": { "callback": "team:create" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "✨ Let's set up your team!\n\nFirst, what's your team called?" }
          }
        ]
      },
      {
        "send": { "text": "Skippers" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Got it! Now let's set up your channel for digests.\n\n**Forward any message from your team's channel** to me — I'll grab the channel ID from it. That's the easiest way." }
          }
        ]
      },
      {
        "send": { "text": "-1009998887770" },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": { "callback": "standup:init" },
        "expect": [
          { "method": "editMessageText", "payload": { "text": "☀️ Starting standup..." } },
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "standup:skip" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "👍 Got it — you're marked as skipped for today's standup." }
          }
        ]
      }
    ]
  }
]